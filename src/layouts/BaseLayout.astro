---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { getLangFromUrl, getLocalizedUrl } from '../i18n/utils';
import { locales, localeLabels, defaultLocale, type Locale } from '../i18n/ui';

interface Props {
  title: string;
  description?: string;
  locale?: Locale;
}

const currentLocale = Astro.props.locale ?? getLangFromUrl(Astro.url);
const { title, description = 'Agentic CMS' } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

// Build hreflang alternate links for SEO
const localesRegex = new RegExp(`^\\/(${locales.join('|')})`);
const currentPath = Astro.url.pathname
  .replace(base, '')
  .replace(localesRegex, '')
  .replace(/^\//, '/');
---

<!doctype html>
<html lang={currentLocale === 'pt-br' ? 'pt-BR' : currentLocale}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href={`${base}/favicon.svg`} />
    <title>{title} | Agentic CMS</title>
    {/* Hreflang alternates for SEO */}
    {locales.map((loc) => (
      <link rel="alternate" hreflang={loc === 'pt-br' ? 'pt-BR' : loc} href={`${Astro.site ? Astro.site.origin : ''}${getLocalizedUrl(loc, currentPath)}`} />
    ))}
    <link rel="alternate" hreflang="x-default" href={`${Astro.site ? Astro.site.origin : ''}${getLocalizedUrl(defaultLocale, currentPath)}`} />
  </head>
  <body class="min-h-dvh flex flex-col bg-gray-950 text-gray-100 font-sans antialiased">
    <Header locale={currentLocale} currentPath={currentPath} />
    <main class="flex-1 w-full max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-10">
      <slot />
    </main>
    <Footer locale={currentLocale} />

    {/* Auto-detect language — runs only on root page, first visit */}
    {Astro.url.pathname === `${base}/` && (
      <script is:inline define:vars={{ base, defaultLocale, locales }}>
        if (!sessionStorage.getItem('lang_detected')) {
          sessionStorage.setItem('lang_detected', '1');
          const browserLang = navigator.language.toLowerCase();
          
          // Find if browser language matches any of our supported locales
          const targetLocale = locales.find(l => 
            browserLang.startsWith(l.split('-')[0])
          );

          if (targetLocale && targetLocale !== defaultLocale) {
            location.replace(`${base}/${targetLocale}/`);
          }
        }
      </script>
    )}
  </body>
</html>
